# Root-level convenience env (copied into infra/env/*.env for containers).
# For real deployments, edit infra/env/*.env directly.

APP_ENV=development
JWT_SECRET=change_me_in_prod
JWT_ALGORITHM=HS256

# JSON array of browser origins allowed to call the API.
CORS_ORIGINS=["http://localhost:3000"]

POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
POSTGRES_DB=rag

MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
MINIO_BUCKET=rag-documents

EMBEDDING_PROVIDER=voyage
EMBEDDING_MODEL=voyage-3
EMBEDDING_DIM=1024
VOYAGE_API_KEY=

RERANKER_PROVIDER=voyage
RERANKER_MODEL=rerank-2-lite

LLM_PROVIDER=anthropic
LLM_SMALL_MODEL=claude-haiku-4-5-20251001
LLM_LARGE_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=
