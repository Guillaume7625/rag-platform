# /etc/rag-platform/secrets.env
#
# Copy this file to /etc/rag-platform/secrets.env on the VPS, fill in real
# values, and lock it down:
#
#   sudo mkdir -p /etc/rag-platform
#   sudo cp secrets.env.example /etc/rag-platform/secrets.env
#   sudo chown root:root /etc/rag-platform/secrets.env
#   sudo chmod 600        /etc/rag-platform/secrets.env
#
# docker-compose.prod.yml is invoked with --env-file /etc/rag-platform/secrets.env
# so every ${VAR} in that compose file is resolved from here.
#
# Never commit the real file.

# --- Domain & TLS -------------------------------------------------------------
DOMAIN=rag.marinenationale.cloud
ACME_EMAIL=you@example.com

# --- PostgreSQL ---------------------------------------------------------------
POSTGRES_DB=rag
POSTGRES_USER=rag
# Generate a strong password, e.g. `openssl rand -base64 32`
POSTGRES_PASSWORD=REPLACE_ME

# --- MinIO --------------------------------------------------------------------
MINIO_ROOT_USER=rag
# Generate a strong password, e.g. `openssl rand -base64 32`
MINIO_ROOT_PASSWORD=REPLACE_ME
MINIO_BUCKET=rag-documents

# --- Qdrant -------------------------------------------------------------------
QDRANT_COLLECTION=rag_chunks

# --- JWT ----------------------------------------------------------------------
# Generate with: openssl rand -hex 64
JWT_SECRET=REPLACE_ME

# --- Anthropic (generation) ---------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
LLM_SMALL_MODEL=claude-haiku-4-5-20251001
LLM_LARGE_MODEL=claude-sonnet-4-6

# --- Voyage AI (embeddings + reranking) ---------------------------------------
VOYAGE_API_KEY=pa-REPLACE_ME
VOYAGE_EMBEDDING_MODEL=voyage-3
VOYAGE_RERANK_MODEL=rerank-2-lite
