APP_ENV=development
API_PORT=8000
LOG_LEVEL=INFO
ROOT_PATH=

# JSON array of browser origins allowed to call the API.
CORS_ORIGINS=["http://localhost:3000"]

DATABASE_URL=postgresql+psycopg://rag:rag@postgres:5432/rag
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=rag_chunks

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123
MINIO_BUCKET=rag-documents
MINIO_SECURE=false

JWT_SECRET=change_me_in_prod
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=1440

# --- Embeddings (Voyage AI) ---
EMBEDDING_PROVIDER=voyage
EMBEDDING_MODEL=voyage-3
EMBEDDING_DIM=1024
VOYAGE_API_KEY=

# --- Reranker (Cohere default, Voyage fallback) ---
RERANKER_PROVIDER=cohere
RERANKER_MODEL=rerank-v3.5
COHERE_API_KEY=

# --- LLM (Anthropic) ---
LLM_PROVIDER=anthropic
LLM_SMALL_MODEL=claude-haiku-4-5-20251001
LLM_LARGE_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

RETRIEVAL_TOP_K=50
RERANK_TOP_K=20
CONTEXT_TOP_K=6

CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
